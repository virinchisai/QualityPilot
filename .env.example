ENVIRONMENT=development
DATABASE_URL=sqlite:///./qualitypilot.db
JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_MINUTES=1440
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SECONDS=60
QUALITYPILOT_API_URL=http://localhost:8001
DEMO_APP_URL=http://localhost:8000
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
# Demo-only fault injection. All must remain false outside a controlled demo.
DEFECT_DISABLE_REFRESH_ROTATION=false
DEFECT_ALLOW_EXPIRED_TOKENS=false
DEFECT_BREAK_ADMIN_AUTH=false
DEFECT_DELAY_MS=0
DEFECT_INCORRECT_STATUS=false
DEFECT_UNSTABLE_SELECTOR=false
DEFECT_RANDOM_FAILURE=false
DEFECT_MALFORMED_JSON=false

